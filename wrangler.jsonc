{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "txlink",
  "compatibility_date": "2026-05-25",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "txlink.stupidtech.net",
      "custom_domain": true
    }
  ]
}
